# ─────────────────────────────────────────────────────────────────
# TorqLens — environment variable TEMPLATE (safe to commit)
# Copy to `.env.local` for local dev and fill in real values there.
# NEVER commit `.env` / `.env.local` with real values.
# ─────────────────────────────────────────────────────────────────

# Base URL of the TorqLens backend the (iOS) client calls.
# - Local web dev:  http://localhost:3000
# - Production:     an https:// URL (required for the iOS bundle)
# The iOS app reads this at BUILD time and only ever calls this backend.
NEXT_PUBLIC_API_BASE_URL=https://your-backend.example.com

# ─────────────────────────────────────────────────────────────────
# SERVER-ONLY. These are read by the backend (API routes) at runtime.
# They are NEVER bundled into the client or the iOS app.
# Configure them in your hosting provider's secret store
# (e.g. Vercel Project Settings → Environment Variables), not here.
# ─────────────────────────────────────────────────────────────────

# The backend's plant-identification model is read server-side via this key.
# Set it ONLY in the host's secret manager (e.g. Vercel → Environment
# Variables). Never place it in any client-readable (NEXT_PUBLIC_*) variable,
# and never commit a real value.
ANTHROPIC_API_KEY=
